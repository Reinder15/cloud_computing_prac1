https://pve.proxmox.com/pve-docs/pve-admin-guide.html#chapter_pct
# Download Ubuntu/Debian LXC template
pveam update
pveam available | grep ubuntu
pveam download local ubuntu-25.04-standard_25.04-1.1_amd64.tar.zst
pveam list local

# Maak LXC container
pct create 100 local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst \
  --hostname wordpress-training \
  --memory 2048 \
  --net0 name=eth0,bridge=vmbr0,ip=10.24.38.10/24,gw=10.24.38.1 \
  --nameserver 8.8.8.8 \
  --onboot 1 \
  --start 1 \
  --storage ceph-pool

# Start container en installeer WordPress MANUEEL:
pct start 100
pct enter 100

# In de container:
https://developer.wordpress.org/advanced-administration/before-install/howto-install/
apt update && apt upgrade -y
apt install apache2 mysql-server php php-mysql libapache2-mod-php php-cli php-curl php-gd php-mbstring php-xml php-xmlrpc -y
wget https://wordpress.org/latest.tar.gz
tar -xzf latest.tar.gz
mv wordpress /var/www/html/

https://developer.wordpress.org/advanced-administration/before-install/creating-database/
mysql
mysql> CREATE DATABASE myWordPressDatabase;  
mysql> CREATE USER "admin"@"localhost" IDENTIFIED BY "admin";
mysql> GRANT ALL PRIVILEGES ON myWordPressDatabase.* TO "admin"@"localhost";
mysql> FLUSH PRIVILEGES;  
mysql> EXIT

touch /var/www/html/wp-config.php
# Vul wp-config.php in met database gegevens

