wget -q https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img

qemu-img resize noble-server-cloudimg-amd64.img 30G

export CUSTOM_USER_NAME=ubuntu
export CUSTOM_USER_PASSWORD=password

qm create 1000 --name "ubuntu-2404-cloudinit-template" --ostype l26 \
    --memory 1024 \
    --agent 1 \
    --bios ovmf --machine q35 --efidisk0 local-lvm:0,pre-enrolled-keys=0 \
    --cpu host --socket 1 --cores 1 \
    --vga serial0 --serial0 socket  \
    --net0 virtio,bridge=vmbr0

qm importdisk 1000 noble-server-cloudimg-amd64.img local-lvm

qm set 1000 --scsihw virtio-scsi-pci --virtio0 local-lvm:vm-1000-disk-1,discard=on

qm set 1000 --boot order=virtio0
qm set 1000 --ide2 local-lvm:cloudinit

cat << 'EOF' | tee /var/lib/vz/snippets/vendor.yaml
#cloud-config
package_update: true
package_upgrade: false
packages:
    - qemu-guest-agent
runcmd:
    - systemctl enable --now qemu-guest-agent
EOF

qm set 1000 --cicustom "vendor=local:snippets/vendor.yaml"
qm set 1000 --tags ubuntu-template,24.04,cloudinit
qm set 1000 --ciuser $CUSTOM_USER_NAME --ciupgrade 0
qm set 1000 --cipassword $(openssl passwd -6 $CUSTOM_USER_PASSWORD)
qm set 1000 --sshkeys /mnt/pve/cephfs/.ssh/authorized_keys
qm set 1000 --ipconfig0 ip=dhcp

qm cloudinit update 1000

qm template 1000

qm clone 1000 470 --name ubuntu-2404-test -full -storage local-lvm
qm set 470 --net0 virtio,bridge=vmbr0,rate=50
qm set 470 --ipconfig0 ip=10.24.38.78/24,gw=10.24.38.1
qm resize 470 virtio0 30G
qm set 470 --core 1 --memory 1024 --balloon 0
qm set 470 --nameserver 8.8.8.8
qm start 470




